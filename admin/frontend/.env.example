# Black Rabbit Cloner - Frontend Configuration
# Copy this file to .env and fill in values

# Artists API
VITE_ARTISTS_API_URL=
VITE_ARTISTS_API_KEY=
VITE_ARTISTS_PER_PAGE=20

# Polling
VITE_POLL_INTERVAL=3000

# Download defaults
VITE_DEFAULT_SCAN_MAX_PAGES=30
VITE_DEFAULT_DOWNLOAD_DEPTH=5
VITE_DEFAULT_SERVER_PORT=3000
VITE_DEFAULT_BACKEND_PORT=3001
